<Window x:Class="IntLimiter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:IntLimiter.ViewModels"
        xmlns:conv="clr-namespace:IntLimiter.Converters"
        xmlns:ctrl="clr-namespace:IntLimiter.Controls"
        mc:Ignorable="d"
        Title="IntLimiter - Network Monitor"
        Height="700" Width="1000"
        MinHeight="500" MinWidth="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <conv:BpsToHumanReadableConverter x:Key="BpsConverter" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisConverter" />
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="12"
            BorderBrush="#404040" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.5" ShadowDepth="0" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="50" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="Transparent" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <TextBlock Text="&#x1F310;" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="IntLimiter" FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
                        <Button x:Name="MinimizeButton" Content="&#x2500;" Width="46" Height="40"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                FontSize="12"
                                Click="MinimizeButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bg" Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bg" Property="Background" Value="#33FFFFFF" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button x:Name="CloseButton" Content="&#x2715;" Width="46" Height="40"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                FontSize="12"
                                Click="CloseButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="0,12,0,0">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bg" Property="Background" Value="#C42B1C" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Tab Bar -->
            <Border Grid.Row="1" Background="#252525" BorderBrush="#333333" BorderThickness="0,1,0,1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                    <RadioButton Content="Monitor" Style="{StaticResource TabButtonStyle}"
                                 IsChecked="True"
                                 GroupName="Tabs"
                                 Checked="MonitorTab_Checked" />
                    <RadioButton Content="Limiter" Style="{StaticResource TabButtonStyle}"
                                 GroupName="Tabs"
                                 Checked="LimiterTab_Checked" />
                    <RadioButton Content="Settings" Style="{StaticResource TabButtonStyle}"
                                 GroupName="Tabs"
                                 Checked="SettingsTab_Checked" />
                </StackPanel>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Row="2">
                <!-- Monitor Tab -->
                <ScrollViewer x:Name="MonitorPanel" VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <!-- Global Stats Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="&#x2191; UPLOAD" Style="{StaticResource CaptionStyle}"
                                               Foreground="{StaticResource UploadBrush}" />
                                    <TextBlock Text="{Binding GlobalSendRate}" Style="{StaticResource StatLargeStyle}"
                                               Foreground="{StaticResource UploadBrush}" Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="&#x2193; DOWNLOAD" Style="{StaticResource CaptionStyle}"
                                               Foreground="{StaticResource DownloadBrush}" />
                                    <TextBlock Text="{Binding GlobalReceiveRate}" Style="{StaticResource StatLargeStyle}"
                                               Foreground="{StaticResource DownloadBrush}" Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding AdapterName}" Style="{StaticResource CaptionStyle}" />
                                    <ctrl:SparklineControl Height="40" Values="{Binding GlobalReceiveHistory}"
                                                           LineColor="#4CAF78" LineThickness="2" Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Apps Header -->
                        <TextBlock Text="Active Network Applications" Style="{StaticResource SubtitleStyle}" Margin="0,0,0,8" />

                        <!-- Apps List -->
                        <Border Style="{StaticResource CardStyle}" Padding="0">
                            <ListView x:Name="AppsListView"
                                      ItemsSource="{Binding Apps}"
                                      Style="{StaticResource ModernListViewStyle}"
                                      ItemContainerStyle="{StaticResource ModernListViewItemStyle}"
                                      MaxHeight="380">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Process" Width="180">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding ProcessName}"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   FontSize="12" />
                                                        <TextBlock Text="{Binding ProcessId, StringFormat='PID {0}'}"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontSize="10" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Upload" Width="120">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding SendRateBps, Converter={StaticResource BpsConverter}}"
                                                               Foreground="{StaticResource UploadBrush}" FontSize="12" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Download" Width="120">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding ReceiveRateBps, Converter={StaticResource BpsConverter}}"
                                                               Foreground="{StaticResource DownloadBrush}" FontSize="12" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Connections" Width="90">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding ConnectionCount}"
                                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Activity" Width="120">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ctrl:SparklineControl Height="28" Width="110"
                                                                           Values="{Binding ReceiveHistory}"
                                                                           LineColor="#4CAF78" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Limiter Tab -->
                <ScrollViewer x:Name="LimiterPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <!-- Global Limits Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Global Bandwidth Limits" Style="{StaticResource SubtitleStyle}" Margin="0,0,0,12" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                        <TextBlock Text="Max Upload (Mbps)" Style="{StaticResource CaptionStyle}" Margin="0,0,0,4" />
                                        <Slider Style="{StaticResource ModernSliderStyle}"
                                                Minimum="0" Maximum="1000"
                                                Value="{Binding GlobalMaxUploadMbps}"
                                                TickFrequency="100" IsSnapToTickEnabled="False" />
                                        <TextBlock Text="{Binding GlobalMaxUploadMbps, StringFormat='{}{0:F0} Mbps'}"
                                                   Foreground="{StaticResource UploadBrush}" FontSize="12" Margin="0,4,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Max Download (Mbps)" Style="{StaticResource CaptionStyle}" Margin="0,0,0,4" />
                                        <Slider Style="{StaticResource ModernSliderStyle}"
                                                Minimum="0" Maximum="1000"
                                                Value="{Binding GlobalMaxDownloadMbps}"
                                                TickFrequency="100" IsSnapToTickEnabled="False" />
                                        <TextBlock Text="{Binding GlobalMaxDownloadMbps, StringFormat='{}{0:F0} Mbps'}"
                                                   Foreground="{StaticResource DownloadBrush}" FontSize="12" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Grid>
                                <Button Content="Apply Global Limit" Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding ApplyGlobalLimitCommand}"
                                        HorizontalAlignment="Left" Margin="0,12,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Per-App Limits -->
                        <TextBlock Text="Per-Application Limits" Style="{StaticResource SubtitleStyle}" Margin="0,0,0,8" />
                        <Border Style="{StaticResource CardStyle}" Padding="0">
                            <ItemsControl ItemsSource="{Binding Apps}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="12,8" BorderBrush="#333333" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="160" />
                                                    <ColumnDefinition Width="140" />
                                                    <ColumnDefinition Width="140" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ProcessName}"
                                                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" />
                                                    <TextBlock Text="{Binding ProcessId, StringFormat='PID {0}'}"
                                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="8,0">
                                                    <TextBlock Text="Upload limit (bps)" Style="{StaticResource CaptionStyle}" />
                                                    <TextBox Text="{Binding MaxUploadBps, StringFormat='{}{0:F0}'}"
                                                             Style="{StaticResource ModernTextBoxStyle}" Width="120" HorizontalAlignment="Left" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Margin="8,0">
                                                    <TextBlock Text="Download limit (bps)" Style="{StaticResource CaptionStyle}" />
                                                    <TextBox Text="{Binding MaxDownloadBps, StringFormat='{}{0:F0}'}"
                                                             Style="{StaticResource ModernTextBoxStyle}" Width="120" HorizontalAlignment="Left" />
                                                </StackPanel>
                                                <CheckBox Grid.Column="3" Content="Enabled"
                                                          Style="{StaticResource ToggleSwitchStyle}"
                                                          IsChecked="{Binding IsLimitEnabled}"
                                                          VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <Button Content="Apply" Style="{StaticResource PrimaryButtonStyle}"
                                                            Command="{Binding DataContext.ApplyAppLimitCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Margin="0,0,8,0" />
                                                    <Button Content="Remove" Style="{StaticResource SecondaryButtonStyle}"
                                                            Command="{Binding DataContext.RemoveAppLimitCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Settings Tab -->
                <ScrollViewer x:Name="SettingsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="General Settings" Style="{StaticResource SubtitleStyle}" Margin="0,0,0,16" />
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="Refresh Interval (ms)" Style="{StaticResource CaptionStyle}" Margin="0,0,0,4" />
                                    <Slider Minimum="250" Maximum="5000"
                                            Value="{Binding RefreshIntervalMs}"
                                            TickFrequency="250" IsSnapToTickEnabled="True"
                                            Width="300" HorizontalAlignment="Left" />
                                    <TextBlock Text="{Binding RefreshIntervalMs, StringFormat='{}{0} ms'}"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox Content="Dark Theme" Style="{StaticResource ToggleSwitchStyle}"
                                              IsChecked="{Binding IsDarkTheme}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="About IntLimiter" Style="{StaticResource SubtitleStyle}" Margin="0,0,0,8" />
                                <TextBlock Text="Windows 11-style network activity monitor and bandwidth limiter."
                                           Style="{StaticResource CaptionStyle}" TextWrapping="Wrap" />
                                <TextBlock Text="Requires administrator privileges for bandwidth limiting (WFP)."
                                           Style="{StaticResource CaptionStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
